三、权限说明
权限值	说明	对应接口
record	查看记录数据	/api/today/records、/api/records
calendar	查看日历数据	/api/calendar
stats	查看统计数据	/api/stats
四、curl 测试命令
bash
BASE="http://localhost:8000/api"
TOKEN="Bearer your-token-here"

# 1. 创建守护关系
curl -X POST "$BASE/guardian/create" \
  -H "Authorization: $TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"target_id": "uuid-of-user-b", "permissions": ["record", "calendar"]}'

# 2. 获取守护请求详情
curl -X GET "$BASE/guardian/detail?relation_id=1" -H "Authorization: $TOKEN"

# 3. 确认守护
curl -X POST "$BASE/guardian/confirm" \
  -H "Authorization: $TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"relation_id": 1, "accept": true}'

# 4. 获取守护列表
curl -X GET "$BASE/guardian/list" -H "Authorization: $TOKEN"

# 5. 查看被守护者的日历（需要权限）
curl -X GET "$BASE/calendar?year=2026&month=5&target_user_id=uuid-of-user-b" \
  -H "Authorization: $TOKEN"

# 6. 查看被守护者的今日记录（需要权限）
curl -X GET "$BASE/today/records?target_user_id=uuid-of-user-b" \
  -H "Authorization: $TOKEN"

# 7. 移除守护关系
curl -X POST "$BASE/guardian/remove" \
  -H "Authorization: $TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"relation_id": 1}'
